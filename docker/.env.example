# Production environment variables template
# Copy this to .env and fill in real values

# Database
DB_PASSWORD=your_secure_postgres_password
DATABASE_URL=postgresql://postgres:${DB_PASSWORD}@postgres-prod:5432/opentrail_db

# JWT
JWT_SECRET=your_long_random_secret_key_at_least_32_characters

# GitHub OAuth
GITHUB_API_TOKEN=your_github_personal_access_token
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret

# URLs
FRONTEND_URL=https://yourdomain.com
FRONTEND_API_URL=https://api.yourdomain.com

# n8n
N8N_PASSWORD=your_secure_n8n_password
N8N_API_KEY=your_n8n_api_key

# Email (for future use)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
